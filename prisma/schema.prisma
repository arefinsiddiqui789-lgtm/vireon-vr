generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model StudyTask {
  id          String   @id @default(cuid())
  subject     String
  title       String
  description String?
  dayOfWeek   Int      @default(0)
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DailyGoal {
  id        String   @id @default(cuid())
  title     String
  completed Boolean  @default(false)
  date      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GoalStreak {
  id          String   @id @default(cuid())
  currentDate String   @unique
  count       Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model GymExercise {
  id        String   @id @default(cuid())
  name      String
  sets      Int      @default(3)
  reps      Int      @default(10)
  completed Boolean  @default(false)
  dayOfWeek Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GymLog {
  id        String   @id @default(cuid())
  date      String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CodeSnippet {
  id        String   @id @default(cuid())
  title     String
  language  String   @default("python")
  code      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String
  content   String
  createdAt DateTime @default(now())
}
